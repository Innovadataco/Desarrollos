# Configuración de base de datos
DATABASE_URL=postgresql://innovadataco:innovadataco_dev@localhost:5432/proteccion_infantil

# Encriptación de reportes en reposo (AES-256)
# Debe ser exactamente 32 bytes (64 caracteres hex). Generar con:
# python -c "import secrets; print(secrets.token_hex(32))"
REPORT_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Rate limiting (opcional, por defecto en memoria)
# REDIS_URL=redis://localhost:6379/0

# App
APP_NAME=ProteccionInfantil
DEBUG=True
